{
  "name": "ozzy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Monorepo tooling for ozzy",
  "workspaces": [
    "apps/web",
    "packages/ozzy-node-sdk"
  ],
  "scripts": {
    "build": "bun run api:build && bun run cli:build",
    "build:web": "bun --cwd apps/web run build",
    "dev:web": "bun --cwd apps/web run dev",
    "test:web": "bun --cwd apps/web run test",
    "openapi": "cargo build -p ozzy-api",
    "api:build": "cargo build -p ozzy-api",
    "api:dev": "wrangler dev -e test --cwd crates/ozzy-api",
    "api:deploy": "wrangler deploy --cwd crates/ozzy-api",
    "cli:build": "cargo build -p ozzy-cli",
    "cli:install": "cargo install --path crates/ozzy-cli --force",
    "sdk:build": "bun run --cwd packages/ozzy-node-sdk build",
    "sdk:rebuild": "bun run openapi && bun run sdk:build",
    "sdk:clean": "bun --cwd packages/ozzy-node-sdk run clean",
    "sdk:publish": "bun run openapi && (cd packages/ozzy-node-sdk && npm publish)",
    "workspace:install:web": "bun --cwd apps/web install",
    "workspace:install:sdk": "bun --cwd packages/ozzy-node-sdk install",
    "workspace:install": "bun install && bun run workspace:install:web && bun run workspace:install:sdk",
    "test:api": "cargo test -p ozzy-api",
    "test:cli": "cargo test -p ozzy-cli",
    "test:all": "cargo test"
  }
}
